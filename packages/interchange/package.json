{
  "name": "interchange",
  "version": "0.1.3",
  "description": "Multi-model agent orchestrator with intelligent routing and context translation",
  "type": "module",
  "bin": {
    "interchange": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "@npow/interchange-core": "*",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ai": "^4.0.0",
    "commander": "^12.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.0.0"
  }
}
